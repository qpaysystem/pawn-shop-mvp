APP_NAME="Ломбард MVP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Moscow
APP_LOCALE=ru

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pawn_shop_mvp
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

# Лендинг ломбарда (название и телефон в шапке/футере)
LOMBARD_NAME="Ломбард"
LOMBARD_PHONE="+7 (383) 291-00-51"

# Распознавание текста с фото: Gemini (приоритет) или Vision
# Gemini — бесплатный tier: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Vision: Google Cloud Console → Vision API → Credentials
# GOOGLE_VISION_API_KEY=

# Извлечение полей из текста паспорта через LLM (OpenAI). Тот же ключ — для транскрипции записей звонков (Whisper).
# Ключ: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Deep Seek: анализ фото паспорта, оформление расшифровки разговоров (пунктуация, реплики).
# Ключ: https://platform.deepseek.com/api_keys (платный, но дешёвый)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Serper — похожие объявления Авито и фото при AI-оценке. Бесплатно 2500 запросов/мес.
# Ключ: https://serper.dev
# SERPER_API_KEY=

# 1С LMB API — данные контрагента по телефону: GET {url}/user/{phone}, Basic Auth UserWebServis/UserWebServis
# LMB_USER_API_URL=http://5.128.186.3/lmb/hs/es
# LMB_USER_API_USERNAME=UserWebServis
# LMB_USER_API_PASSWORD=UserWebServis

# Пользователь 1С (логин в конфигурацию) — для веб-сервисов, требующих авторизацию пользователя 1С (не для БД)
# LMB_1C_USER=
# LMB_1C_PASSWORD=

# Прямое подключение к БД 1С для изучения структуры (php artisan lmb:db-schema). Доступ только по VPN.
# Найти хост в VPN: ./scripts/find_mssql_host_vpn.sh
# PostgreSQL: LMB_DB_DRIVER=pgsql, LMB_DB_PORT=5432. MS SQL: LMB_DB_DRIVER=sqlsrv, LMB_DB_PORT=1433.
# LMB_DB_DRIVER=pgsql
# LMB_DB_HOST=192.168.7.250
# LMB_DB_PORT=5432
# LMB_DB_DATABASE=lmb
# LMB_DB_USERNAME=lmb
# LMB_DB_PASSWORD=lmb

# Синхронизация филиалов 1С в stores (php artisan lmb:sync-stores-from-1c). По умолчанию _reference197.
# LMB_1C_STORES_REFERENCE_TABLE=_reference197
# LMB_1C_STORES_NAME_COLUMN=_description
# LMB_1C_STORES_ADDRESS_COLUMN=_fld5205

# Синхронизация контрагентов 1С в раздел «Клиенты» (php artisan lmb:sync-contragents). Физлица: _reference122x1.
# LMB_1C_CONTRAGENT_TABLE=_reference122x1
# LMB_1C_CONTRAGENT_PHONE_COLUMN=_fld41084
# LMB_1C_CONTRAGENT_NAME_COLUMN=_fld3178
# LMB_1C_CONTRAGENT_DATE_CREATED_COLUMN=_fld3191
# LMB_1C_CONTRAGENT_TRAFFIC_SOURCE_COLUMN=_fld41085rref
# LMB_1C_TRAFFIC_SOURCE_REF_TABLE= (таблица справочника «Источник рекламы» в 1С, если известна)

# Договоры скупки из 1С (Скупка ценностей → purchase_contracts + items). Таблица известна: _document389x1.
# LMB_1C_PURCHASE_DOCUMENT_TABLE=_document389x1
# LMB_1C_PURCHASE_CONTRAGENT_COLUMN=_fld9626rref
# LMB_1C_PURCHASE_DATE_COLUMN=_date_time
# LMB_1C_PURCHASE_NUMBER_COLUMN=_number
# LMB_1C_PURCHASE_AMOUNT_COLUMN=_fld9631
# LMB_1C_PURCHASE_NAME_COLUMNS=_fld9638,_fld9643,_fld9650
# LMB_1C_PURCHASE_STORE_COLUMN=_fld9627rref
# LMB_1C_PURCHASE_DEFAULT_STORE_ID=1

# Договоры залога из 1С (Операция по залогу → pawn_contracts + items). Таблицу найти: php artisan lmb:discover-1c-documents --count --exclude-known --with-vt. См. docs/LMB_INTEGRATION_FULL.md
# LMB_1C_PAWN_DOCUMENT_TABLE=
# LMB_1C_PAWN_CONTRAGENT_COLUMN=_fld3195rref
# LMB_1C_PAWN_DATE_COLUMN=_date_time
# LMB_1C_PAWN_NUMBER_COLUMN=_number
# LMB_1C_PAWN_AMOUNT_COLUMN=
# LMB_1C_PAWN_PERCENT_COLUMN=
# LMB_1C_PAWN_EXPIRY_COLUMN=
# LMB_1C_PAWN_BUYBACK_AMOUNT_COLUMN=
# LMB_1C_PAWN_TABLE_PART_TABLE=
# LMB_1C_PAWN_VT_DOC_ID_COLUMN=
# LMB_1C_PAWN_VT_NOMENCLATURE_COLUMN=
# LMB_1C_PAWN_VT_AMOUNT_COLUMN=
# LMB_1C_PAWN_VT_DESCRIPTION_COLUMN=
# LMB_1C_PAWN_DEFAULT_STORE_ID=1
# Склад/филиал в документе 1С (если есть): ссылка на справочник складов → маппинг по stores.lmb_store_uid или LMB_1C_PAWN_STORE_MAPPING
# LMB_1C_PAWN_STORE_COLUMN=
# Доп. маппинг hex_uid_1c => store_id (JSON), например {"80e10050569c4e3011e7365a18a6185b":1}
# LMB_1C_PAWN_STORE_MAPPING={}
# Создавать клиента-заглушку для неизвестного контрагента (залоги переносятся)
# LMB_1C_PAWN_CREATE_PLACEHOLDER_CLIENT=false

# MTS телефония → колл-центр
# MTS_TELEPHONY_API: auto (по умолчанию) — AC20, если заданы MTS_AC20_DOMAIN и MTS_AC20_TRUNK_ID из 10 цифр; иначе VPBX. Явно: vpbx | ac20
# Только VPBX: не задавайте MTS_AC20_DOMAIN/TRUNK_ID или укажите MTS_TELEPHONY_API=vpbx
# MTS_TELEPHONY_API=vpbx
# MTS_VPBX_URL=https://vpbx.mts.ru
# MTS_VPBX_PASSWORD=
# AC20 (Автосекретарь 2.0): https://aa.mts.ru/api/ac20/index.html — JWT в Authorization: Bearer
# MTS_VPBX_PASSWORD=eyJ...  # JWT из ЛК
# MTS_AC20_BASE_URL=https://aa.mts.ru/api/ac20
# MTS_AC20_DOMAIN=ваш-домен.example.ru
# MTS_AC20_TRUNK_ID=1234567890

# 2ГИС — данные карточки организации в разделе «Маркетинг» (рейтинг, отзывы). Ключ: platform.2gis.ru, ID филиала — из ссылки на карточку в 2ГИС.
# DGIS_API_KEY=
# DGIS_BRANCH_ID=
